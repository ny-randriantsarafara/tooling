#!/usr/bin/env bash
# gen-env — interactive .env generator from AWS ECS / SSM / Secrets Manager
# Config: ~/.config/gen-env/config.json
set -euo pipefail

VERSION="1.0.0"
CONFIG_FILE="${GEN_ENV_CONFIG:-$HOME/.config/gen-env/config.json}"

# ── Load modules ─────────────────────────────────────────────────────────────
# Figure out where this script lives so we can find lib/ next to it.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

source "${LIB_DIR}/colors.sh"     # ANSI color codes
source "${LIB_DIR}/helpers.sh"    # info, ok, warn, die, expand_path, count_lines
source "${LIB_DIR}/config.sh"     # load_config, cfg
source "${LIB_DIR}/ui.sh"         # print_banner, select_from_list, select_with_all
source "${LIB_DIR}/auth.sh"       # check_credentials, offer_refresh
source "${LIB_DIR}/sources.sh"    # fetch_sources, merge_with_template

# ── --list command ───────────────────────────────────────────────────────────

cmd_list() {
  load_config
  echo
  bold "Companies & projects:"

  local company_count
  company_count=$(cfg '.companies | length')

  for (( ci=0; ci<company_count; ci++ )); do
    local cid cname
    cid=$(cfg ".companies[$ci].id")
    cname=$(cfg ".companies[$ci].name")
    echo -e "  ${BOLD}${cid}${RESET}  (${cname})"

    local proj_count
    proj_count=$(cfg ".companies[$ci].projects | length")

    for (( pi=0; pi<proj_count; pi++ )); do
      local pid pname ppath
      pid=$(cfg ".companies[$ci].projects[$pi].id")
      pname=$(cfg ".companies[$ci].projects[$pi].name")
      ppath=$(expand_path "$(cfg ".companies[$ci].projects[$pi].path")")

      local has_services
      has_services=$(cfg ".companies[$ci].projects[$pi] | has(\"services\")")

      if [[ "$has_services" == "true" ]]; then
        echo -e "    ${CYAN}${pid}${RESET}  ${DIM}${ppath}${RESET}"
        local svc_count
        svc_count=$(cfg ".companies[$ci].projects[$pi].services | length")
        for (( si=0; si<svc_count; si++ )); do
          local sid envlist
          sid=$(cfg ".companies[$ci].projects[$pi].services[$si].id")
          envlist=$(cfg ".companies[$ci].projects[$pi].services[$si].envs | keys | join(\" \")")
          local first_env output
          first_env=$(cfg ".companies[$ci].projects[$pi].services[$si].envs | keys[0]")
          output=$(cfg ".companies[$ci].projects[$pi].services[$si].envs[\"$first_env\"].output // \"\"")

          local prefix="├"
          [[ $si -eq $(( svc_count - 1 )) ]] && prefix="└"
          echo -e "      ${prefix} ${sid}  ${DIM}envs: ${envlist}${RESET}$([ -n "$output" ] && echo "  ${DIM}→  ${output}${RESET}")"
        done
      else
        local envlist
        envlist=$(cfg ".companies[$ci].projects[$pi].envs | keys | join(\" \")")
        echo -e "    ${CYAN}${pid}${RESET}  ${DIM}${ppath}   envs: ${envlist}${RESET}"
      fi
    done
  done
  echo
}

# ── generate_env ─────────────────────────────────────────────────────────────
# Fetches env vars for one project/service + environment combo.
# Sets globals: LAST_ENV_OUTPUT (file path) and LAST_ENV_VARS (content).

LAST_ENV_OUTPUT=""
LAST_ENV_VARS=""

generate_env() {
  local ci="$1" pi="$2" env_name="$3" si="$4" profile="$5"
  local label

  if [[ "$si" == "-1" ]]; then
    label=$(cfg ".companies[$ci].projects[$pi].name")
  else
    label=$(cfg ".companies[$ci].projects[$pi].services[$si].name")
  fi

  # Region: service-level overrides project-level
  local region
  if [[ "$si" != "-1" ]]; then
    region=$(cfg ".companies[$ci].projects[$pi].services[$si].aws_region // .companies[$ci].projects[$pi].aws_region")
  else
    region=$(cfg ".companies[$ci].projects[$pi].aws_region")
  fi

  # Sources JSON array
  local sources_json
  if [[ "$si" != "-1" ]]; then
    sources_json=$(echo "$CONFIG" | jq -c ".companies[$ci].projects[$pi].services[$si].envs[\"$env_name\"].sources // []")
  else
    sources_json=$(echo "$CONFIG" | jq -c ".companies[$ci].projects[$pi].envs[\"$env_name\"].sources // []")
  fi

  # Output file path
  local output_rel
  if [[ "$si" != "-1" ]]; then
    output_rel=$(cfg ".companies[$ci].projects[$pi].services[$si].envs[\"$env_name\"].output")
  else
    output_rel=$(cfg ".companies[$ci].projects[$pi].envs[\"$env_name\"].output")
  fi
  local project_path
  project_path=$(expand_path "$(cfg ".companies[$ci].projects[$pi].path")")
  local output_abs="${project_path}/${output_rel}"

  # Template file (optional)
  local template_rel=""
  if [[ "$si" != "-1" ]]; then
    template_rel=$(cfg ".companies[$ci].projects[$pi].services[$si].template // \"\"")
    [[ -z "$template_rel" || "$template_rel" == "null" ]] && \
      template_rel=$(cfg ".companies[$ci].projects[$pi].template // \"\"")
  else
    template_rel=$(cfg ".companies[$ci].projects[$pi].template // \"\"")
  fi
  local template_abs=""
  [[ -n "$template_rel" && "$template_rel" != "null" ]] && \
    template_abs="${project_path}/${template_rel}"

  # Fetch from AWS sources
  local src_count
  src_count=$(echo "$sources_json" | jq 'length')

  local fetched=""
  if (( src_count > 0 )); then
    local tmpfile
    tmpfile=$(mktemp)
    trap "rm -f '$tmpfile'" RETURN
    info "${label} — Fetching..." >&2
    fetch_sources "$sources_json" "$profile" "$region" > "$tmpfile" || {
      rm -f "$tmpfile"
      die "Fetch failed for $label"
    }
    fetched=$(cat "$tmpfile")
    rm -f "$tmpfile"
  else
    ok "${label} — template only"
  fi

  # Merge with template (fills in missing keys)
  if [[ -n "$template_abs" && -f "$template_abs" ]]; then
    fetched=$(merge_with_template "$fetched" "$template_abs")
  fi

  local var_count
  var_count=$(count_lines "$fetched")
  ok "${label}  →  ${var_count} vars  →  ${output_rel}"

  LAST_ENV_OUTPUT="$output_abs"
  LAST_ENV_VARS="$fetched"
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
  # ── Parse arguments ──────────────────────────────────────────────────────
  local opt_company="" opt_project="" opt_service="" opt_env=""
  local opt_output="" opt_dry_run=false opt_refresh_creds=false
  local opt_list=false opt_help=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --company)        opt_company="$2";      shift 2 ;;
      --project)        opt_project="$2";      shift 2 ;;
      --service)        opt_service="$2";      shift 2 ;;
      --env)            opt_env="$2";          shift 2 ;;
      --output)         opt_output="$2";       shift 2 ;;
      --dry-run)        opt_dry_run=true;      shift ;;
      --refresh-creds)  opt_refresh_creds=true; shift ;;
      --list)           opt_list=true;         shift ;;
      --help|-h)        opt_help=true;         shift ;;
      *) die "Unknown option: $1. Use --help for usage." ;;
    esac
  done

  if $opt_help; then
    cat <<EOF

  ${BOLD}gen-env${RESET} v${VERSION} — interactive .env generator

  ${BOLD}Usage:${RESET}
    gen-env [options]

  ${BOLD}Options:${RESET}
    --company <id>      Select company by id
    --project <id>      Select project by id
    --service <id>      Select service by id (monorepos)
    --env <name>        Select environment (dev/staging/prod/...)
    --output <file>     Override output file path
    --dry-run           Print vars to stdout, don't write file
    --refresh-creds     Force credential refresh before fetching
    --list              List all companies, projects, services
    --help              Show this help

  ${BOLD}Config:${RESET}
    ${CONFIG_FILE}

EOF
    exit 0
  fi

  load_config

  if $opt_list; then
    cmd_list
    exit 0
  fi

  print_banner

  # ── Step 1: Pick a company ───────────────────────────────────────────────
  local company_count
  company_count=$(cfg '.companies | length')
  (( company_count > 0 )) || die "No companies in config."

  local ci=0
  if [[ -n "$opt_company" ]]; then
    local found=false
    for (( i=0; i<company_count; i++ )); do
      if [[ "$(cfg ".companies[$i].id")" == "$opt_company" ]]; then
        ci=$i; found=true; break
      fi
    done
    $found || die "Company not found: $opt_company"
  elif (( company_count == 1 )); then
    ci=0
    info "Company › $(cfg ".companies[0].name")  ${DIM}(auto-selected — only 1)${RESET}"
  else
    local company_names=()
    for (( i=0; i<company_count; i++ )); do
      company_names+=("$(cfg ".companies[$i].name")")
    done
    local selected_company
    selected_company=$(select_from_list "Company" "${company_names[@]}")
    for (( i=0; i<company_count; i++ )); do
      [[ "$(cfg ".companies[$i].name")" == "$selected_company" ]] && ci=$i && break
    done
  fi

  local auth_type
  auth_type=$(cfg ".companies[$ci].auth.type")

  # ── Step 2: Pick a project ──────────────────────────────────────────────
  local proj_count
  proj_count=$(cfg ".companies[$ci].projects | length")
  (( proj_count > 0 )) || die "No projects for company: $(cfg ".companies[$ci].name")"

  local pi=-1
  if [[ -n "$opt_project" ]]; then
    for (( i=0; i<proj_count; i++ )); do
      if [[ "$(cfg ".companies[$ci].projects[$i].id")" == "$opt_project" ]]; then
        pi=$i; break
      fi
    done
    (( pi >= 0 )) || die "Project not found: $opt_project"
  else
    # Try to auto-detect from current directory
    local cwd
    cwd=$(pwd)
    for (( i=0; i<proj_count; i++ )); do
      local ppath
      ppath=$(expand_path "$(cfg ".companies[$ci].projects[$i].path")")
      if [[ "$cwd" == "$ppath" || "$cwd" == "$ppath/"* ]]; then
        pi=$i
        break
      fi
    done

    if (( pi >= 0 )); then
      local ppath
      ppath=$(expand_path "$(cfg ".companies[$ci].projects[$pi].path")")
      info "Project:  ${DIM}(auto-detected from ${ppath})${RESET}"
      echo -e "    ${GREEN}❯${RESET} $(cfg ".companies[$ci].projects[$pi].name")   ${DIM}${ppath}${RESET}"
    else
      local proj_names=()
      for (( i=0; i<proj_count; i++ )); do
        proj_names+=("$(cfg ".companies[$ci].projects[$i].name")")
      done
      local selected_proj
      selected_proj=$(select_from_list "Project" "${proj_names[@]}")
      for (( i=0; i<proj_count; i++ )); do
        [[ "$(cfg ".companies[$ci].projects[$i].name")" == "$selected_proj" ]] && pi=$i && break
      done
    fi
  fi

  local profile_group
  profile_group=$(cfg ".companies[$ci].projects[$pi].profile_group")

  # ── Step 3: Pick a service (monorepos only) ─────────────────────────────
  local has_services do_all_services=false
  has_services=$(cfg ".companies[$ci].projects[$pi] | has(\"services\")")

  local selected_services=()

  if [[ "$has_services" == "true" ]]; then
    local svc_count
    svc_count=$(cfg ".companies[$ci].projects[$pi].services | length")

    if [[ -n "$opt_service" ]]; then
      if [[ "$opt_service" == "all" || "$opt_service" == "ALL" ]]; then
        do_all_services=true
        for (( i=0; i<svc_count; i++ )); do selected_services+=($i); done
      else
        for (( i=0; i<svc_count; i++ )); do
          if [[ "$(cfg ".companies[$ci].projects[$pi].services[$i].id")" == "$opt_service" ]]; then
            selected_services=($i); break
          fi
        done
        (( ${#selected_services[@]} > 0 )) || die "Service not found: $opt_service"
      fi
    else
      local svc_names=()
      for (( i=0; i<svc_count; i++ )); do
        svc_names+=("$(cfg ".companies[$ci].projects[$pi].services[$i].name")")
      done
      local selected_svc
      selected_svc=$(select_with_all "Service" "${svc_names[@]}")

      if [[ "$selected_svc" == "ALL" ]]; then
        do_all_services=true
        for (( i=0; i<svc_count; i++ )); do selected_services+=($i); done
      else
        for (( i=0; i<svc_count; i++ )); do
          [[ "$(cfg ".companies[$ci].projects[$pi].services[$i].name")" == "$selected_svc" ]] && selected_services=($i) && break
        done
      fi
    fi
  else
    selected_services=(-1)  # -1 means "simple project, no services"
  fi

  # ── Step 4: Pick an environment ─────────────────────────────────────────
  local env_names=()
  if [[ "${selected_services[0]}" == "-1" ]]; then
    while IFS= read -r e; do env_names+=("$e"); done < \
      <(cfg ".companies[$ci].projects[$pi].envs | keys[]")
  else
    while IFS= read -r e; do env_names+=("$e"); done < \
      <(cfg ".companies[$ci].projects[$pi].services[${selected_services[0]}].envs | keys[]")
  fi

  local env_name=""
  if [[ -n "$opt_env" ]]; then
    local valid=false
    for e in "${env_names[@]}"; do [[ "$e" == "$opt_env" ]] && valid=true && break; done
    $valid || die "Environment not found: $opt_env"
    env_name="$opt_env"
  elif (( ${#env_names[@]} == 1 )); then
    env_name="${env_names[0]}"
    info "Environment: ${env_name}  ${DIM}(auto-selected — only 1)${RESET}"
  else
    env_name=$(select_from_list "Environment" "${env_names[@]}")
  fi

  # ── Step 5: Check AWS credentials ──────────────────────────────────────
  local aws_profile
  aws_profile=$(echo "$CONFIG" | jq -r ".companies[$ci].profile_map[\"$profile_group\"][\"$env_name\"]")
  [[ -z "$aws_profile" || "$aws_profile" == "null" ]] && \
    die "No AWS profile for group '$profile_group' env '$env_name'"

  echo
  info "AWS Profile: ${aws_profile}"

  if $opt_refresh_creds; then
    offer_refresh "$auth_type" "$aws_profile"
  else
    local cred_status
    cred_status=$(check_credentials "$auth_type" "$aws_profile")
    case "$cred_status" in
      valid:*)  ok "Credentials valid (expires in ${cred_status#valid:})" ;;
      static)   ok "Static profile — no expiry check" ;;
      expired)  offer_refresh "$auth_type" "$aws_profile" ;;
      *)        warn "Could not verify credentials for profile: $aws_profile" ;;
    esac
  fi

  echo

  # ── Step 6: Fetch env vars ─────────────────────────────────────────────
  declare -a all_outputs=()
  declare -a all_vars=()

  if $do_all_services; then
    for si_iter in "${selected_services[@]}"; do
      generate_env "$ci" "$pi" "$env_name" "$si_iter" "$aws_profile"
      all_outputs+=("$LAST_ENV_OUTPUT")
      all_vars+=("$LAST_ENV_VARS")
    done
    echo
    local total_vars=0
    for v in "${all_vars[@]}"; do
      local c; c=$(count_lines "$v"); total_vars=$(( total_vars + c ))
    done
    info "Total: ${#all_outputs[@]} files, ${total_vars} vars"
  else
    generate_env "$ci" "$pi" "$env_name" "${selected_services[0]}" "$aws_profile"
    all_outputs+=("$LAST_ENV_OUTPUT")
    all_vars+=("$LAST_ENV_VARS")
    echo
    info "Output: ${LAST_ENV_OUTPUT}  ($(count_lines "$LAST_ENV_VARS") vars total)"
  fi

  # ── Step 7: Write / Preview / Quit ─────────────────────────────────────
  if $opt_dry_run; then
    echo
    bold "── Dry run — preview ──────────────────────────"
    for (( i=0; i<${#all_outputs[@]}; i++ )); do
      echo
      echo -e "  ${CYAN}# ${all_outputs[$i]}${RESET}"
      echo "${all_vars[$i]}"
    done
    echo
    exit 0
  fi

  local write_label="Write"
  $do_all_services && write_label="Write all"

  echo
  echo -ne "  ${BOLD}[W]${RESET} ${write_label}   ${BOLD}[P]${RESET} Preview   ${BOLD}[Q]${RESET} Quit  > "
  local action
  read -r action

  case "${action,,}" in
    w|"")
      for (( i=0; i<${#all_outputs[@]}; i++ )); do
        mkdir -p "$(dirname "${all_outputs[$i]}")"
        printf '%s\n' "${all_vars[$i]}" > "${all_outputs[$i]}"
        ok "Written: ${all_outputs[$i]}"
      done
      ;;
    p)
      echo
      for (( i=0; i<${#all_outputs[@]}; i++ )); do
        bold "── ${all_outputs[$i]} ──"
        echo "${all_vars[$i]}"
        echo
      done
      ;;
    q)
      info "Quit."
      ;;
    *)
      warn "Unknown action: $action"
      ;;
  esac
}

main "$@"
