{
  "name": "api-regression-validator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compare": "tsx src/cli.ts",
    "api": "tsx src/api/server.ts",
    "web": "cd web && npx vite --open",
    "dev": "concurrently --names api,web --prefix-colors blue,green \"npm run api\" \"cd web && npx vite\"",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "devDependencies": {
    "@types/json-diff": "^1.0.3",
    "concurrently": "^9.2.1",
    "tsx": "^4",
    "typescript": "^5"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "json-diff": "^1.0.6"
  }
}
